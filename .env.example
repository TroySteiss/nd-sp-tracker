# Copy to .env for local development. Railway injects DATABASE_URL and PORT automatically.

# Postgres connection string. Local default below matches the winget PostgreSQL install.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sp_tracker

# Port the server listens on. Railway sets this automatically in production.
PORT=3000

# Secret used to sign session cookies. Generate a long random string for production.
SESSION_SECRET=change-me-to-a-long-random-string

# Shared password gate (v1 auth). Everyone on the team uses this to log in.
APP_PASSWORD=northdakota

# Where uploaded bid PDFs are stored. On Railway, point this at a mounted volume.
UPLOAD_DIR=./data/uploads

# Set to "production" on Railway so secure cookies are enforced.
NODE_ENV=development
